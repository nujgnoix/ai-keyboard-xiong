{
  "windows": {
    "删除全文": {
      "actions": [
        {
          "type": "key_combo",
          "keys": [
            "ctrl",
            "a"
          ],
          "description": "全选全文"
        },
        {
          "type": "key_combo",
          "keys": [
            "delete"
          ],
          "description": "删除选中内容"
        }
      ]
    },
    "把前三个字放大": {
      "actions": [
        {
          "type": "key_combo",
          "keys": [
            "shift",
            "left"
          ],
          "description": "向左选中第一个字"
        },
        {
          "type": "key_combo",
          "keys": [
            "shift",
            "left"
          ],
          "description": "向左选中第二个字"
