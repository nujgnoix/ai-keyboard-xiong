            "ctrl",
            "b"
          ],
          "description": "加粗选中的文字"
        },
        {
          "type": "key_combo",
          "keys": [
            "right"
          ],
          "description": "取消选中并光标归位"
        }
      ]
    },
    "输入今晚打老虎用26号字": {
