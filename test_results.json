            "shift",
            "left"
          ],
          "description": "向左选中第三个字"
        },
        {
          "type": "key_combo",
          "keys": [
            "ctrl",
            "shift",
            ">"
          ],
          "description": "放大选中的三个字"
        },
        {
          "type": "key_combo",
          "keys": [
            "right"
          ],
          "description": "取消选中，光标归位"
        }
      ]
    },
    "把前三个字加粗": {
      "actions": [
        {
          "type": "key_combo",
